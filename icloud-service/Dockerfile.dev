# Dev Dockerfile – dependencies baked in, source mounted as volume, hot-reload via uvicorn --reload
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt debugpy

EXPOSE 8000 5678

# Source tree is bind-mounted by compose.dev.yaml.
# debugpy listens on 5678; uvicorn --reload watches /app for .py changes.
CMD ["python", "-m", "debugpy", "--listen", "0.0.0.0:5678", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
