# Cloud Synchronizer – environment variables
# Copy this file to .env.local and fill in real values. Never commit secrets.

# --- OpenRouter (LLM for DiskDetectionAgent) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use (default: google/gemini-2.0-flash-001 – cheap & smart, supports tool calling)
# Other good options:
#   mistralai/mistral-small-3.1-24b-instruct
#   anthropic/claude-3-5-haiku-20241022
#   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- App credentials ---
APP_USERNAME=admin
APP_PASSWORD=changeme

# --- Paths ---
EXTERNAL_DRIVE_PATH=/mnt/external-drive
THUMBNAIL_DIR=/mnt/external-drive/thumbnails
SCRIPTS_DIR=/scripts

# --- iCloud microservice ---
ICLOUD_SERVICE_URL=http://icloud-service:8000
