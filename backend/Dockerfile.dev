# Dev Dockerfile – JVM build (no GraalVM native compile, much faster)
FROM gradle:8-jdk21 AS builder

WORKDIR /app

# Cache dependencies (gradle binary comes from the base image, no wrapper needed)
COPY settings.gradle.kts build.gradle.kts ./
RUN gradle dependencies --no-daemon || true

# Build fat JAR
COPY src ./src
RUN gradle shadowJar --no-daemon -x test

# Runtime image – JRE is enough
FROM eclipse-temurin:21-jre-jammy

WORKDIR /app

# Install tools needed by agent tools and scripts
RUN apt-get update && apt-get install -y --no-install-recommends \
    util-linux \
    mount \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/build/libs/*-all.jar app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]
