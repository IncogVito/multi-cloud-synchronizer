# Dev Dockerfile – single-stage, source mounted as volume, hot-reload via gradle run -t
FROM gradle:8-jdk21

WORKDIR /app

# Pre-cache dependencies into the image layer (speeds up first start significantly)
COPY settings.gradle.kts build.gradle.kts ./
COPY gradle ./gradle
RUN gradle dependencies --no-daemon || true

# Install OS tools needed by scripts and the healthcheck
USER root
RUN sed -i 's|URIs: http://|URIs: https://|g' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null; \
    sed -i 's|^deb http://|deb https://|g' /etc/apt/sources.list 2>/dev/null; \
    sed -i '/^Components:/ { /universe/! s/$/ universe/ }' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null; \
    sed -i 's/^\(deb https:\/\/.*\) main$/\1 main universe/' /etc/apt/sources.list 2>/dev/null; \
    true
RUN apt-get update -o Acquire::Retries=3 && apt-get install -y --no-install-recommends \
    wget \
    util-linux \
    mount \
    libvips-tools \
    libheif1 \
    && rm -rf /var/lib/apt/lists/*

# Ensure volumes mounted at runtime are owned by gradle user
RUN mkdir -p /home/gradle/.gradle /app/build && chown -R gradle:gradle /home/gradle/.gradle /app/build

USER gradle

EXPOSE 8080

# Continuous mode: recompiles and restarts Micronaut whenever a source file changes.
# The source tree is bind-mounted by compose.dev.yaml – no COPY needed here.
#
# The shell wrapper removes any stale Gradle lock files left behind when the
# container was previously killed (SIGKILL) or when a host-side Gradle process
# ran against the same bind-mounted .gradle directory and didn't clean up.
CMD ["sh", "-c", "find /app/.gradle -name '*.lock' -delete 2>/dev/null; exec gradle run -t --no-daemon --stacktrace"]
