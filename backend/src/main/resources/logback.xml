<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- %xEx drukuje pełny stacktrace łącznie z przyczyną (cause chain) -->
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] [%logger{40}] - %msg%n%xEx</pattern>
        </encoder>
    </appender>

    <!-- Datasource / Hikari -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="com.zaxxer.hikari.HikariConfig" level="WARN"/>

    <!-- Our app -->
    <logger name="com.cloudsync" level="DEBUG"/>

    <!-- HTTP Server - tylko requests i responses -->
    <logger name="io.micronaut.http.server.netty.RoutingInBoundHandler" level="DEBUG"/>
    <logger name="io.micronaut.http.server.netty.NettyRequestLifecycle" level="DEBUG"/>

    <!-- Wyłącz verbose framework logery -->
    <logger name="io.micronaut.context.DefaultBeanContext" level="WARN"/>
    <logger name="io.micronaut.security" level="WARN"/>
    <logger name="io.micronaut.http.server.netty.RoutingInBoundHandler.decorator" level="WARN"/>

    <!-- Root at INFO -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
