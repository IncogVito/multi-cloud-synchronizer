<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- %xEx drukuje pełny stacktrace łącznie z przyczyną (cause chain) -->
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] [%logger{40}] - %msg%n%xEx</pattern>
        </encoder>
    </appender>

    <!-- Datasource / Hikari -->
    <logger name="com.zaxxer.hikari" level="DEBUG"/>
    <logger name="com.zaxxer.hikari.HikariConfig" level="DEBUG"/>

    <!-- Our app -->
    <logger name="com.cloudsync" level="DEBUG"/>

    <!-- Root at INFO to cut noise -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
